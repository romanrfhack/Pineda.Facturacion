{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "LegacyRead": {
    "ConnectionString": "Server=localhost;Port=3306;Database=ipn;User ID=root;Password=Root123!;"
  },
  "BillingWrite": {
    "ConnectionString": "Server=localhost;Port=3306;Database=facturacion_v2;User ID=root;Password=Root123!;"
  },
  "FacturaloPlus": {
    "BaseUrl": "https://dev.facturaloplus.com/api/rest/servicio/",
    "StampPath": "timbrarJSON3",
    "PaymentComplementStampPath": "/cfdi/payment-complement/stamp",
    "CancelPath": "/cfdi/cancel",
    "StatusQueryPath": "/cfdi/status",
    "PaymentComplementCancelPath": "/cfdi/payment-complement/cancel",
    "PaymentComplementStatusQueryPath": "/cfdi/payment-complement/status",
    "ProviderName": "FacturaloPlus",
    "PayloadMode": "JsonSnapshot",
    "ApiKeyHeaderName": "X-Api-Key",
    "ApiKeyReference": "FACTURALO_SANDBOX_APIKEY_EXAMPLE",
    "TimeoutSeconds": 30
  },
  "SecretReferences": {
    "Values": {
      "FACTURALOPLUS_API_KEY_REFERENCE": "FACTURALO_SANDBOX_APIKEY_EXAMPLE",
      "CSD_CERTIFICATE_REFERENCE": "FACTURALO_SANDBOX_CER_PEM_EXAMPLE",
      "CSD_PRIVATE_KEY_REFERENCE": "FACTURALO_SANDBOX_KEY_PEM_EXAMPLE",
      "CSD_PRIVATE_KEY_PASSWORD_REFERENCE": "FACTURALO_SANDBOX_KEY_PASSWORD_EXAMPLE"
    }
  },
  "Auth": {
    "Jwt": {
      "Issuer": "Pineda.Facturacion.Sandbox",
      "Audience": "Pineda.Facturacion.Api",
      "SigningKey": "SANDBOX_ONLY_CHANGE_ME_MIN_32_CHARACTERS",
      "ExpiresMinutes": 480
    },
    "BootstrapAdmin": {
      "Enabled": true,
      "Username": "admin.test",
      "DisplayName": "Sandbox Admin",
      "Password": "SANDBOX_ONLY_Test123!"
    }
  },
  "Bootstrap": {
    "ApplyMigrationsOnStartup": true,
    "ApplyStandardVat16BackfillOnStartup": false,
    "SeedDefaultRoles": true,
    "SeedDefaultTestUsers": true,
    "DefaultTestUserPassword": "SANDBOX_ONLY_Test123!"
  },
  "OpenApi": {
    "EnableSwagger": true
  },
  "SmtpEmail": {
    "Host": "smtp-sandbox-placeholder.local",
    "Port": 587,
    "EnableSsl": true,
    "Username": "sandbox-user-placeholder",
    "Password": "[SANDBOX_ONLY_REPLACE_ME]",
    "FromAddress": "sandbox@example.com",
    "FromDisplayName": "Pineda Facturacion Sandbox"
  },
  "IssuerLogoStorage": {
    "RootPath": "App_Data/issuer-logos",
    "MaxFileSizeBytes": 1048576
  }
}
