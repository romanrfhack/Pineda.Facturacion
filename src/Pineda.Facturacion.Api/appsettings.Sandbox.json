{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "LegacyRead": {
    "ConnectionString": ""
  },
  "BillingWrite": {
    "ConnectionString": ""
  },
  "FacturaloPlus": {
    "BaseUrl": "https://dev.facturaloplus.com/api/rest/servicio/",
    "StampPath": "timbrarJSON3",
    "PaymentComplementStampPath": "timbrarJSON3",
    "CancelPath": "cancelar2",
    "StatusQueryPath": "consultarEstadoSAT",
    "RemoteCfdiQueryPath": "consultarCFDI",
    "PendingCancellationAuthorizationsPath": "consultarAutorizacionesPendientes",
    "CancellationAuthorizationDecisionPath": "autorizarCancelacion",
    "PaymentComplementCancelPath": "/cfdi/payment-complement/cancel",
    "PaymentComplementStatusQueryPath": "/cfdi/payment-complement/status",
    "ProviderName": "FacturaloPlus",
    "PayloadMode": "JsonSnapshot",
    "ApiKeyHeaderName": "X-Api-Key",
    "ApiKeyReference": "FACTURALOPLUS_API_KEY_REFERENCE",
    "TimeoutSeconds": 30
  },
  "SecretReferences": {
    "Values": {
      "FACTURALOPLUS_API_KEY_REFERENCE": "",
      "CSD_CERTIFICATE_REFERENCE": "",
      "CSD_PRIVATE_KEY_REFERENCE": "",
      "CSD_PRIVATE_KEY_PASSWORD_REFERENCE": ""
    }
  },
  "Auth": {
    "Jwt": {
      "Issuer": "Pineda.Facturacion.Sandbox",
      "Audience": "Pineda.Facturacion.Api",
      "SigningKey": "",
      "ExpiresMinutes": 480
    },
    "BootstrapAdmin": {
      "Enabled": true,
      "Username": "admin.test",
      "DisplayName": "Sandbox Admin",
      "Password": ""
    }
  },
  "Bootstrap": {
    "ApplyMigrationsOnStartup": true,
    "ApplyStandardVat16BackfillOnStartup": false,
    "SeedDefaultRoles": true,
    "SeedDefaultTestUsers": true,
    "DefaultTestUserPassword": ""
  },
  "OpenApi": {
    "EnableSwagger": true
  },
  "Email": {
    "SafeRecipient": "pinedaautorefacciones@gmail.com",
    "ProductionBccRecipient": "pinedaautorefacciones@gmail.com"
  },
  "SmtpEmail": {
    "Host": "smtp-sandbox-placeholder.local",
    "Port": 587,
    "EnableSsl": true,
    "Username": "sandbox-user-placeholder",
    "Password": "",
    "FromAddress": "sandbox@example.com",
    "FromDisplayName": "Pineda Facturacion Sandbox"
  },
  "IssuerLogoStorage": {
    "RootPath": "App_Data/issuer-logos",
    "MaxFileSizeBytes": 1048576
  }
}
