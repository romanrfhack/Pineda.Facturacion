{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "LegacyRead": {
    "ConnectionString": "Server=localhost;Port=3306;Database=ipn;User ID=root;Password=Root123!;"
  },
  "BillingWrite": {
    "ConnectionString": "Server=localhost;Port=3306;Database=facturacion_v2;User ID=root;Password=Root123!;"
  },
  "FacturaloPlus": {
    "BaseUrl": "https://dev.facturaloplus.com/api/rest/servicio/",
    "StampPath": "timbrarJSON3",
    "PaymentComplementStampPath": "cfdi/payment-complement/stamp",
    "CancelPath": "cancelar2",
    "StatusQueryPath": "consultarEstadoSAT",
    "RemoteCfdiQueryPath": "consultarCFDI",
    "PendingCancellationAuthorizationsPath": "consultarAutorizacionesPendientes",
    "CancellationAuthorizationDecisionPath": "autorizarCancelacion",
    "PaymentComplementCancelPath": "/cfdi/payment-complement/cancel",
    "PaymentComplementStatusQueryPath": "/cfdi/payment-complement/status",
    "ProviderName": "FacturaloPlus",
    "PayloadMode": "JsonSnapshot",
    "ApiKeyHeaderName": "X-Api-Key",
    "ApiKeyReference": "FACTURALO_SANDBOX_APIKEY_EXAMPLE",
    "TimeoutSeconds": 30
  },
  "SecretReferences": {
    "Values": {
      "FACTURALOPLUS_API_KEY_REFERENCE": "PLACEHOLDER_API_KEY",
      "CSD_CERTIFICATE_REFERENCE": "PLACEHOLDER_CERTIFICATE_VALUE_OR_PATH",
      "CSD_PRIVATE_KEY_REFERENCE": "PLACEHOLDER_PRIVATE_KEY_VALUE_OR_PATH",
      "CSD_PRIVATE_KEY_PASSWORD_REFERENCE": "PLACEHOLDER_PRIVATE_KEY_PASSWORD"
    }
  },
  "Auth": {
    "Jwt": {
      "Issuer": "Pineda.Facturacion",
      "Audience": "Pineda.Facturacion.Api",
      "SigningKey": "CHANGE_ME_MIN_32_CHARACTERS_FOR_PRODUCTION_USE",
      "ExpiresMinutes": 60
    },
    "BootstrapAdmin": {
      "Enabled": false,
      "Username": "admin",
      "DisplayName": "Bootstrap Admin",
      "Password": "CHANGE_ME_DEV_ONLY"
    }
  },
  "Bootstrap": {
    "ApplyMigrationsOnStartup": false,
    "ApplyStandardVat16BackfillOnStartup": false,
    "SeedDefaultRoles": true,
    "SeedDefaultTestUsers": false,
    "DefaultTestUserPassword": "CHANGE_ME_NON_PRODUCTION_ONLY"
  },
  "OpenApi": {
    "EnableSwagger": false
  },
  "SmtpEmail": {
    "Host": "",
    "Port": 587,
    "EnableSsl": true,
    "Username": "",
    "Password": "",
    "FromAddress": "",
    "FromDisplayName": "Pineda Facturacion"
  },
  "IssuerLogoStorage": {
    "RootPath": "App_Data/issuer-logos",
    "MaxFileSizeBytes": 1048576
  },
  "AllowedHosts": "*"
}
