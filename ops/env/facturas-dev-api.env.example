# Persistent server-side environment for facturas-dev-api.service
# Copy this file to /etc/facturas-dev/facturas-dev-api.env on the VPS.
# Keep real secrets out of the repo and out of /var/www/facturas-dev-backend/publish.
# Avoid '%' in new passwords stored here unless you explicitly escape it for systemd.

ASPNETCORE_ENVIRONMENT=Sandbox
RuntimeSafety__AllowSandboxEnvironment="true"

# Required external configuration for Sandbox startup in DEV.
LegacyRead__ConnectionString=Server=127.0.0.1;Port=3306;Database=legacy_db;User ID=legacy_readonly;Password=REPLACE_WITH_SECRET_NO_PERCENT;
ConnectionStrings__BillingWrite=Server=127.0.0.1;Port=3306;Database=facturacion_dev;User ID=billing_rw;Password=REPLACE_WITH_SECRET_NO_PERCENT;
Auth__Jwt__SigningKey=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
Auth__BootstrapAdmin__Password=REPLACE_WITH_SECRET_NO_PERCENT
Bootstrap__DefaultTestUserPassword=REPLACE_WITH_SECRET_NO_PERCENT

# SMTP / Email delivery.
# Real values must live only in /etc/facturas-dev/facturas-dev-api.env on the VPS.
# Never commit the real SmtpEmail__Password value.
SmtpEmail__Host="mail.privateemail.com"
SmtpEmail__Port="587"
SmtpEmail__EnableSsl="true"
SmtpEmail__Username="facturacion@autorefaccionespineda.site"
SmtpEmail__Password="<SMTP_PASSWORD>"
SmtpEmail__FromAddress="facturacion@autorefaccionespineda.site"
SmtpEmail__FromDisplayName="Autorefacciones Pineda Sandbox"

# Email safety policy.
Email__SafeRecipient="pinedaautorefacciones@gmail.com"
Email__ProductionBccRecipient="pinedaautorefacciones@gmail.com"

# Optional dotenv-style names supported by the app for the same settings.
# EMAIL_SAFE_RECIPIENT=pinedaautorefacciones@gmail.com
# EMAIL_PRODUCTION_BCC=pinedaautorefacciones@gmail.com

# Optional but recommended for multiline PAC/CSD secret material.
# Point this to a persistent JSON file outside publish, for example:
# /etc/facturas-dev/facturas-dev-secretreferences.json
SecretReferences__ExternalJsonPath=/etc/facturas-dev/facturas-dev-secretreferences.json
